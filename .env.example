# Copy this file to .env and fill in your API keys

# Anthropic (Claude) - for script cleanup
# Get your key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ElevenLabs - for AI voice cloning
# Get your key at: https://elevenlabs.io/settings/api-keys
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Your cloned voice ID from ElevenLabs (set after you create your voice clone)
ELEVENLABS_VOICE_ID=your_voice_id_here

# YouTube / Google OAuth
# Get credentials at: https://console.cloud.google.com/apis/credentials
# Download the OAuth 2.0 client JSON and save as config/client_secrets.json
